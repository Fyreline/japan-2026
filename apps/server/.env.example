# Copy this file to `.env`. Real values only ever live in the gitignored
# apps/server/.env on the household Mac — never commit real values here
# (docs/AUTH.md §4).

ENVIRONMENT=development

# Where this proxy verifies logins (docs/AUTH.md §2). Must be loopback or
# https — identity.py refuses a plain-http non-loopback URL at startup.
# Mishka Hub's API runs on 127.0.0.1:8000.
MISHKA_BASE_URL=http://127.0.0.1:8000

# Supabase project — dashboard → Project Settings → API.
SUPABASE_URL=https://<project-ref>.supabase.co

# The anon/publishable key — the same public key apps/web bakes into its
# bundle (apps/web/.env.example's VITE_SUPABASE_ANON_KEY).
SUPABASE_ANON_KEY=sb_publishable_<same public key the web app uses>

# THE MOST SENSITIVE CREDENTIAL IN THIS PROJECT (docs/AUTH.md §4). Dashboard
# → Project Settings → API → service_role (click to reveal). Bypasses row-
# level security entirely, on the project holding the household's real trip
# data. NEVER commit a real value here, never log it, never put it in
# apps/web or anything VITE_*-prefixed — those bake into the public bundle
# and the two must never meet.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-here>
