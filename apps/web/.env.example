# Supabase project credentials for the SPA — Vite env vars, baked in at
# build time. Copy this file to .env.local and fill in the two values for
# local dev (see README.md / SUPABASE_SETUP.md). The same two also live as
# GitHub repo *variables* (not secrets) for the Pages build.

# Project URL — Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon / publishable key (sb_publishable_…) — same page. Public by design;
# RLS is the security boundary. NEVER put the service_role key here or
# anywhere else in this repo.
VITE_SUPABASE_ANON_KEY=sb_publishable_...
